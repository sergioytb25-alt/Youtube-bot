# Exemple .env — crée un fichier .env à la racine et remplis les valeurs
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxx
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
# Liste de pseudos Twitch séparés par des virgules (ex: user1,user2)
TWITCH_USER_LOGINS=ton_pseudo_twitch
POLL_INTERVAL_MS=60000
